generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// generator client {
//  provider = "prisma-client-js"
//}

// ═══════════════════════════════════════════════════════════════════════════
// COMPANIES
// ═══════════════════════════════════════════════════════════════════════════
model Company {
  id   Int    @id @default(autoincrement())
  name String

  // Motive integration
  motiveCompanyId         Int?      @unique @map("motive_company_id")
  motiveOauthToken        String?   @map("motive_oauth_token") @db.Text
  motiveOauthRefreshToken String?   @map("motive_oauth_refresh_token") @db.Text
  motiveTokenExpiresAt    DateTime? @map("motive_token_expires_at")

  // Webhook
  webhookSecret String? @map("webhook_secret")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  drivers                  DriverCompanyAssignment[]
  sessions                 DrivingSession[]
  fleetManagerAssignments FleetManagerCompanyAssignment[]

  @@map("companies")
}

// ═══════════════════════════════════════════════════════════════════════════
// DRIVERS
// ═══════════════════════════════════════════════════════════════════════════
model Driver {
  id           Int     @id @default(autoincrement())
  phone        String? @unique
  email        String? @unique
  passwordHash String? @map("password_hash")
  name         String?
  fleetManagerPhone String? @map("fleet_manager_phone")

  motiveDriverId Int? @map("motive_driver_id")

  // Device info
  deviceId           String?   @map("device_id")
  devicePlatform     String?   @map("device_platform")
  fcmToken           String?   @map("fcm_token") @db.Text
  fcmTokenUpdatedAt  DateTime? @map("fcm_token_updated_at")
  allowlistSelectionEnabled Boolean @default(false) @map("allowlist_selection_enabled")

  isActive   Boolean   @default(true) @map("is_active")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  companies DriverCompanyAssignment[]
  sessions  DrivingSession[]
  pushCommands PushCommand[]
  allowlistSelections DriverAllowlistSelection[]

  @@index([phone])
  @@index([email])
  @@index([motiveDriverId])
  @@map("drivers")
}

// ═══════════════════════════════════════════════════════════════════════════
// DRIVER-COMPANY ASSIGNMENTS (Many-to-Many with role)
// ═══════════════════════════════════════════════════════════════════════════
model DriverCompanyAssignment {
  id        Int @id @default(autoincrement())
  driverId  Int @map("driver_id")
  companyId Int @map("company_id")

  // Role per company
  role String // 'driver', 'co_passenger', 'cleaner'

  // Motive driver ID specific to this company
  motiveDriverIdInCompany Int? @map("motive_driver_id_in_company")

  isActive Boolean  @default(true) @map("is_active")
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([driverId, companyId])
  @@index([driverId])
  @@index([companyId])
  @@map("driver_company_assignments")
}

// ═══════════════════════════════════════════════════════════════════════════
// DRIVING SESSIONS (Created automatically from webhooks)
// ═══════════════════════════════════════════════════════════════════════════
model DrivingSession {
  id        Int    @id @default(autoincrement())
  sessionId String @unique @map("session_id")

  // Who & Where
  driverId       Int @map("driver_id")
  companyId      Int @map("company_id")
  motiveDriverId Int @map("motive_driver_id")

  // Timing
  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  // Status
  dutyStatus String @map("duty_status") // 'driving', 'on_duty', 'off_duty'

  // Blocking state
  blockingActive Boolean @default(false) @map("blocking_active")
  requestedBlockingState Boolean? @map("requested_blocking_state")
  appliedBlockingState Boolean? @map("applied_blocking_state")
  lastCommandId String? @map("last_command_id")
  lastAckAt DateTime? @map("last_ack_at")
  lastAckReason String? @map("last_ack_reason")
  blockedApps    Json?   @map("blocked_apps") // Snapshot of apps blocked

  // Metrics
  totalBlockAttempts Int @default(0) @map("total_block_attempts")
  blockedAttemptAckCount Int @default(0) @map("blocked_attempt_ack_count")
  blockedAttemptPerApp Json? @map("blocked_attempt_per_app")
  blockedAttemptTimestamps Json? @map("blocked_attempt_timestamps")
  blockedAttemptSyncedAt DateTime? @map("blocked_attempt_synced_at")
  lastHeartbeatSentAt DateTime? @map("last_heartbeat_sent_at")
  lastHeartbeatAckAt DateTime? @map("last_heartbeat_ack_at")
  missedHeartbeatCount Int @default(0) @map("missed_heartbeat_count")
  heartbeatCommandId String? @map("heartbeat_command_id")

  // Tamper detection
  isTampered     Boolean?  @default(false) @map("is_tampered")
  tamperedAt     DateTime? @map("tampered_at")
  tamperedReason String?   @map("tampered_reason")

  // Metadata
  vehicleId Int?    @map("vehicle_id")
  deviceId  String? @map("device_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pushCommands PushCommand[]

  @@index([driverId, companyId])
  @@index([companyId, endedAt])
  @@index([sessionId])
  @@map("driving_sessions")
}

model DriverAllowlistSelection {
  id Int @id @default(autoincrement())

  driverId Int @map("driver_id")
  deviceId String @map("device_id")
  selectedApps Json @map("selected_apps")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, deviceId])
  @@index([driverId])
  @@map("driver_allowlist_selections")
}

model PushCommand {
  id BigInt @id @default(autoincrement())

  commandId String @unique @map("command_id")
  driverId Int @map("driver_id")
  sessionId Int? @map("session_id")

  requestedAction String @map("requested_action") // block | unblock
  shouldBlock Boolean @map("should_block")
  dutyStatus String? @map("duty_status")
  source String @default("webhook")

  pushSent Boolean @default(false) @map("push_sent")
  sseSent Boolean @default(false) @map("sse_sent")
  sentAt DateTime? @map("sent_at")

  ackApplied Boolean? @map("ack_applied")
  ackSource String? @map("ack_source")
  ackTimestamp DateTime? @map("ack_timestamp")
  ackReason String? @map("ack_reason") @db.Text
  ackDeviceId String? @map("ack_device_id")
  rawAck Json? @map("raw_ack")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  driver  Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  session DrivingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([driverId, createdAt])
  @@index([sessionId])
  @@index([ackApplied])
  @@map("push_commands")
}

// ═══════════════════════════════════════════════════════════════════════════
// FLEET MANAGERS (Firebase Auth → dashboard)
// ═══════════════════════════════════════════════════════════════════════════
model FleetManager {
  id          Int      @id @default(autoincrement())
  firebaseUid String @unique @map("firebase_uid")
  email       String?
  name        String?
  /** Label shown on fleet dashboard + driver lock screen (may differ from linked Company.name). */
  companyName   String? @map("company_name")
  /** Emergency / dispatch number callable on the driver app while the safety lock is active. */
  contactNumber String? @map("contact_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  companies FleetManagerCompanyAssignment[]

  @@index([firebaseUid])
  @@map("fleet_managers")
}

model FleetManagerCompanyAssignment {
  id             Int      @id @default(autoincrement())
  fleetManagerId Int      @map("fleet_manager_id")
  companyId      Int      @map("company_id")
  role           String   @default("viewer")
  isActive       Boolean  @default(true) @map("is_active")
  joinedAt       DateTime @default(now()) @map("joined_at")

  fleetManager FleetManager @relation(fields: [fleetManagerId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([fleetManagerId, companyId])
  @@index([fleetManagerId])
  @@index([companyId])
  @@map("fleet_manager_company_assignments")
}

// ═══════════════════════════════════════════════════════════════════════════
// MOTIVE WEBHOOKS (Audit log of all webhooks received)
// ═══════════════════════════════════════════════════════════════════════════
model MotiveWebhook {
  id BigInt @id @default(autoincrement())

  // Webhook metadata
  action  String @map("action") // 'user_duty_status_updated'
  trigger String @map("trigger") // 'created', 'updated', 'deleted'

  // Driver info from Motive
  motiveDriverId Int     @map("motive_driver_id") // webhook.id field
  driverRole     String? @map("driver_role") // 'driver', 'admin'
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  username       String? @map("username")

  // Company (if available in webhook)
  driverCompanyId Int? @map("driver_company_id") // Motive's company ID

  // Full payload from Motive
  payload Json

  // Parsed duty status
  dutyStatus         String? @map("duty_status")
  previousDutyStatus String? @map("previous_duty_status") // We'll track this ourselves

  // Processing status
  processingStatus String    @default("pending") @map("processing_status")
  processedAt      DateTime? @map("processed_at")
  errorMessage     String?   @map("error_message") @db.Text

  // Link to our driver (if found)
  ourDriverId Int? @map("our_driver_id")

  // Link to created/updated session
  sessionId Int? @map("session_id")

  receivedAt DateTime @default(now()) @map("received_at")

  @@index([motiveDriverId, receivedAt])
  @@index([processingStatus])
  @@index([ourDriverId])
  @@index([driverCompanyId])
  @@map("motive_webhooks")
}
